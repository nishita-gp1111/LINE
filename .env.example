# App
NEXT_PUBLIC_AUTH_MODE=auto
NEXT_PUBLIC_APP_URL=
APP_ENV=development
APP_TIMEZONE=Asia/Tokyo
MOCK_LINE_API=true
LINE_MANUAL_SEND_ENABLED=false
MOCK_LINE_SEND_OUTCOME=success
ADMIN_EMAIL_ALLOWLIST=

# Launch safety
HOSTING_COMMERCIAL_USE_CONFIRMED=false
LINE_BULK_SEND_ENABLED=false
LINE_SCHEDULED_SEND_ENABLED=false
LINE_AUTOMATION_SEND_ENABLED=false
LINE_AUTO_REPLY_ENABLED=false
LINE_MEDIA_SEND_ENABLED=false
LINE_RICH_MENU_MUTATION_ENABLED=false
LINE_TRACKING_ENABLED=true

# Supabase public
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase server only
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

# LINE Messaging API
LINE_ORGANIZATION_ID=
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_ADMIN_USER_ID=

# LINE Login / LIFF
NEXT_PUBLIC_LIFF_ID=
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=

# Cron
CRON_SECRET=
SCHEDULER_PROVIDER=supabase_cron
SCHEDULER_STALE_AFTER_MINUTES=5

# Campaign and media limits
MAX_CAMPAIGN_RECIPIENTS=50000
MAX_MULTICAST_BATCH_SIZE=500
LINE_MEDIA_BUCKET=line-public-media
MEDIA_IMAGE_MAX_BYTES=8388608
MEDIA_VIDEO_MAX_BYTES=52428800
MEDIA_AUDIO_MAX_BYTES=20971520
MEDIA_STORAGE_WARNING_BYTES=734003200
MEDIA_STORAGE_STOP_BYTES=943718400

# Tracking
TRACKING_SIGNING_SECRET=
TRACKING_TOKEN_TTL_SECONDS=2592000

# Automation
AUTOMATION_MAX_ATTEMPTS=3
AUTOMATION_LEASE_SECONDS=120

# Launch retention
CAMPAIGN_DETAIL_RETENTION_DAYS=90
JOB_RETENTION_DAYS=90
ANALYTICS_EVENT_RETENTION_DAYS=730

# Retention / limits
MEDIA_RETENTION_DAYS=30
WEBHOOK_RETENTION_DAYS=30
MESSAGE_RETENTION_DAYS=365
DB_WARNING_BYTES=367001600
DB_STOP_BYTES=471859200
STORAGE_WARNING_BYTES=734003200
STORAGE_STOP_BYTES=943718400
LINE_QUOTA_RESERVE_PERCENT=3

# Survey
SURVEY_DEFAULT_SESSION_TTL_HOURS=24
SURVEY_MAX_QUESTIONS=50
SURVEY_MAX_QUICK_REPLY_OPTIONS=13
SURVEY_POSTBACK_TOKEN_SECRET=
